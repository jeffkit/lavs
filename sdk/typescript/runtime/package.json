{
  "name": "lavs-runtime",
  "version": "0.2.0",
  "description": "LAVS (Local Agent View Service) server-side runtime - manifest loading, handler execution, validation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "test:run": "vitest run",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "bin": {
    "lavs-runtime": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "lavs",
    "agent",
    "view",
    "service",
    "runtime",
    "manifest",
    "validation",
    "mcp",
    "model-context-protocol"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jeffkit/lavs.git",
    "directory": "sdk/typescript/runtime"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "minimatch": "^9.0.5"
  },
  "devDependencies": {
    "@types/node": "^20.5.0",
    "typescript": "^5.1.6",
    "vitest": "^2.1.0"
  }
}
