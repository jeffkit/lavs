  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "lavs",
    "agent",
    "view",
    "service",
    "protocol",
    "types",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jeffkit/lavs.git",
    "directory": "sdk/typescript/types"
  },
  "devDependencies": {
    "typescript": "^5.1.6"
  }
}
